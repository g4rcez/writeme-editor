{
  "compilerOptions": {
    "target": "es2024",
    "module": "node20",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": "./",
    "outDir": "dist",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "ESNext"],
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
